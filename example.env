# GOPHRDRV Configuration Environment Variables
# Copy this file to '.env' and edit the values as needed.

# The root directory to serve files from.
# If not specified, defaults to the current working directory.
# GOPHRDRV_ROOT=/path/to/files

# The port to listen on.
# Default is 8080.
GOPHRDRV_PORT=8080

# The host address to bind to.
# Default is 0.0.0.0 (all interfaces).
GOPHRDRV_HOST=0.0.0.0

# Read timeout duration.
# Default is 30s.
GOPHRDRV_READ_TIMEOUT=30s

# Write timeout duration.
# Default is 30s.
GOPHRDRV_WRITE_TIMEOUT=30s

# Maximum upload size.
# Supports B, KB, MB, GB (e.g., 500MB, 2GB). Default is 100MB.
GOPHRDRV_MAX_UPLOAD=100MB
